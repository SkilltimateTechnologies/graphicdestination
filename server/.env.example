# --- Turso ---
# Get these from `turso db show <db-name>` and `turso db tokens create <db-name>`
# Leave both unset to fall back to a local SQLite file (useful for local dev).
TURSO_DATABASE_URL=libsql://your-db-name-yourorg.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# --- Server ---
PORT=8787
# NODE_ENV=production makes config validation fail-fast: a missing/weak
# JWT_SECRET, a half-configured Turso, or ENABLE_ADMIN_HINT=1 will refuse to boot.
NODE_ENV=production
CLIENT_ORIGIN=https://your-deployed-domain.com

# --- Observability ---
# Log verbosity for the structured JSON logger: debug | info | warn | error.
LOG_LEVEL=info
# Optional error tracking. No-op unless BOTH this is set AND @sentry/node is
# installed (`cd server && npm install @sentry/node`). Leave blank to disable.
# SENTRY_DSN=
# RELEASE=                        # optional: version/commit tagged on events
# SENTRY_TRACES_SAMPLE_RATE=0     # 0 = errors only (default)
